# Privy app id — sign up at https://privy.io and paste here.
# When unset, the dashboard shows a configuration notice instead of crashing.
NEXT_PUBLIC_PRIVY_APP_ID=

# Solana devnet RPC. Use a Helius/Triton endpoint for higher rate limits.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Vault to load by default on /dashboard. Override per-deployment.
NEXT_PUBLIC_DEFAULT_VAULT_ADDRESS=

# Agent REST API base URL. Run the agent locally with:
#   cd agent && npm run serve
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# Solana cluster used in Solana Explorer links.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
