SOLANA_RPC_URL=https://api.devnet.solana.com
VAULT_ADDRESS=
ADMIN_KEYPAIR_PATH=

# Off-chain salary registry (cleartext amounts the admin already knows). The
# encrypted on-chain ciphertexts are derived from the same numbers; the agent
# uses this file to compute transfer sizes.
SALARIES_PATH=./salaries.json

# Jupiter v6 quote API endpoint. Mainnet pairs only; we use it to demo the
# routing logic — devnet doesn't have Jupiter liquidity to swap against.
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote

# USDC mint (devnet). Leave blank to skip USDC balance reads.
USDC_MINT=

# REST API server (npm run serve)
AGENT_PORT=3001
# When false, POST /api/payroll/execute returns 403. Required because the
# server signs with the admin keypair on disk — leave this on only for
# local dev demos.
AGENT_DEV_MODE=true
